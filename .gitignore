# Git ignore - Files here won't be tracked by git
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# local configuration
*.local

# testing
/coverage

# vercel
.vercel

# next.js outputs
/.next/
/out/

# production
/build

# jetbrains
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/shelf

# logs
logs
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# visual studio code
.vscode/*
!.vscode/settings.json

# operating system files
.DS_Store

# security & certificates
*.pem

# misc
temporary
